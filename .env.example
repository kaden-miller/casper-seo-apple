# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma (Supabase Postgres)
# Pooled connection for application runtime (transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct connection for Prisma migrations (port 5432)
# Use db.[PROJECT_REF].supabase.co or session pooler on port 5432
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Search Console + Google Analytics 4)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 32+ character random secret for encrypting OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=

# Optional: cap crawler page count (unset = crawl entire same-domain site)
# CRAWL_MAX_PAGES=500

# OpenAI (SEO agents)
OPENAI_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4.1-mini

# Reasoning effort for reasoning-capable models only (o-series, gpt-5+)
# Values: none, minimal, low, medium, high, xhigh
# Ignored for gpt-4.x and other non-reasoning models.
# For structured JSON agents, prefer low or medium (high uses more reasoning tokens).
# DEFAULT_AI_REASONING_EFFORT=medium

# Per-agent model overrides (optional)
# DATA_INGESTION_MODEL=gpt-4.1-mini
# TECHNICAL_SEO_MODEL=gpt-4.1-mini
# SEARCH_PERFORMANCE_MODEL=gpt-4.1-mini
# CONTENT_OPPORTUNITY_MODEL=gpt-4.1-mini
# ON_PAGE_SEO_MODEL=gpt-4.1-mini
# COMPETITIVE_ANALYSIS_MODEL=gpt-4.1-mini
# PRIORITIZATION_MODEL=gpt-4.1-mini
# QA_AGENT_MODEL=gpt-4.1-mini
# REPORTING_AGENT_MODEL=gpt-4.1-mini

# Per-agent reasoning effort overrides (optional; falls back to DEFAULT_AI_REASONING_EFFORT)
# TECHNICAL_SEO_REASONING_EFFORT=low
# SEARCH_PERFORMANCE_REASONING_EFFORT=low
# ON_PAGE_SEO_REASONING_EFFORT=medium
# PRIORITIZATION_REASONING_EFFORT=low
# QA_AGENT_REASONING_EFFORT=low
